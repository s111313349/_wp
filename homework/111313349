<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>郭喬甯的個人網頁</title>
    <style>
        /* 基礎設定 */
        body {
            background-color: #f0f2f5;
            font-family: "Microsoft JhengHei", Arial, sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }

        /* 卡片容器 */
        .card {
            background: white;
            padding: 40px;
            border-radius: 15px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            text-align: center;
            max-width: 400px;
            width: 90%;
            border-top: 8px solid #3498db; /* 資工藍 */
        }

        h1 {
            color: #2c3e50;
            margin-bottom: 10px;
        }

        .department {
            color: #3498db;
            font-weight: bold;
            font-size: 1.1em;
            margin-bottom: 20px;
        }

        .info-box {
            text-align: left;
            background: #f8f9fa;
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 20px;
        }

        .info-item {
            margin: 10px 0;
            color: #555;
        }

        .interest {
            color: #8e44ad; /* 心理學紫 */
            font-weight: bold;
        }

        /* 按鈕樣式 */
        .btn {
            display: inline-block;
            background: #3498db;
            color: white;
            padding: 12px 25px;
            text-decoration: none;
            border-radius: 25px;
            transition: 0.3s;
        }

        .btn:hover {
            background: #2980b9;
            transform: scale(1.05);
        }
    </style>
</head>
<body>

    <div class="card">
        <h1>郭喬甯</h1>
        <div class="department">金門大學 資工系</div>
        
        <div class="info-box">
            <div class="info-item">
                <strong>📧 電子郵件：</strong><br>
                s111313349@student.nqu.edu.tw
            </div>
            <div class="info-item">
                <strong>🧠 個人興趣：</strong>
                <span class="interest">心理學</span>
            </div>
        </div>

        <a href="mailto:s111313349@student.nqu.edu.tw" class="btn">發送郵件聯絡我</a>
    </div>

</body>
</html>
